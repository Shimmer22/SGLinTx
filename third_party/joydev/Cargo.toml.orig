[package]
name = "joydev"
version = "0.3.1"
authors = ["Jan Śmiałkowski <gm666q@gm666q.space>"]
edition = "2018"
workspace = ".."
description = "Rust joydev library."
repository = "https://gitlab.com/gm666q/joydev-rs"
readme = "README.md"
keywords = ["api", "input", "linux"]
categories = ["api-bindings", "os::unix-apis"]
license = "GPL-2.0-only"

[badges]
gitlab = { repository = "gm666q/joydev-rs", branch = "master" }
maintenance = { status = "actively-developed" }

[dependencies]
arrayref = "^0.3.6"
input-event-codes = "^0.2.0"
libc = "^0.2.66"
nix = "^0.17.0"

[dependencies.joydev-sys]
version = "^0.2.0"
features = ["extra_traits"]
path = "../joydev-sys"

[dev-dependencies]
ctrlc = "^3"

[package.metadata.docs.rs]
default-target = "x86_64-unknown-linux-gnu"
targets = ["aarch64-unknown-linux-gnu", "armv7-unknown-linux-gnueabihf", "i686-unknown-linux-gnu", "powerpc64le-unknown-linux-gnu", "x86_64-unknown-linux-gnu"]